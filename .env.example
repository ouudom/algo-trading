# =============================================================================
# AlgoTrader — Environment Variables (production)
# Copy to .env on the server and fill in real values.
# NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (external PostgreSQL — provided by you)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://algotrader:CHANGE_ME@your-db-host:5432/algotrader

# ---------------------------------------------------------------------------
# MetaTrader 5
# MT5_HOST/MT5_PORT: the mt5linux Wine socket bridge running on the host.
# When using Docker, set MT5_HOST=host-gateway (docker-compose extra_hosts).
# ---------------------------------------------------------------------------
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=XM-Demo
MT5_HOST=host-gateway
MT5_PORT=18812

# ---------------------------------------------------------------------------
# Telegram notifications (optional — leave blank to disable)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
TRADING_MODE=paper
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
LOG_LEVEL=INFO
DB_ECHO=false

# ---------------------------------------------------------------------------
# CORS — add your domain so the browser can reach the API
# Must be valid JSON array syntax
# ---------------------------------------------------------------------------
CORS_ORIGINS=["https://yourdomain.com"]

# ---------------------------------------------------------------------------
# Frontend build-time variable
# Set to the public URL of your backend (via Nginx).
# This is baked into the Next.js client bundle at docker compose build time.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ---------------------------------------------------------------------------
# Risk settings (optional — defaults defined in configs/settings.py)
# ---------------------------------------------------------------------------
RISK_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_DRAWDOWN_PCT=0.10
