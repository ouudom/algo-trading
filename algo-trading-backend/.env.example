# ============================================================
# AlgoTrader Backend — Environment Variables Template
# Copy to .env and fill in real values.  NEVER commit .env.
# ============================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://algotrader:algotrader@localhost:5432/algotrader

# Set DB_ECHO=true to log all SQL statements during development
DB_ECHO=false

# ---------------------------------------------------------------------------
# API / Frontend
# ---------------------------------------------------------------------------
# Public API URL consumed by the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Additional CORS origins (comma-separated). localhost:3000 is always allowed.
# CORS_ORIGINS=["https://myapp.example.com"]

# Application secret key (for future JWT auth — change before deploying)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# MetaTrader 5
# ---------------------------------------------------------------------------
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=Exness-MT5Real
MT5_TIMEOUT=60000
# Linux only: mt5linux bridge host/port (Wine-based MT5 socket server)
MT5_HOST=127.0.0.1
MT5_PORT=18812

# ---------------------------------------------------------------------------
# Telegram Notifications
# ---------------------------------------------------------------------------
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABCdef...
# Your chat or channel ID (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id

# ---------------------------------------------------------------------------
# Trading Configuration
# ---------------------------------------------------------------------------
# One of: backtest | paper | live
TRADING_MODE=backtest

# Comma-separated list of supported symbols
# SUPPORTED_SYMBOLS=["XAUUSD","EURUSD","GBPUSD","USDJPY","AUDUSD"]

# Supported timeframes
# SUPPORTED_TIMEFRAMES=["H1"]

# ---------------------------------------------------------------------------
# Risk Management
# ---------------------------------------------------------------------------
# Fraction of equity risked per trade (e.g. 0.01 = 1%)
RISK_PCT=0.01

# Daily loss circuit-breaker (e.g. 0.03 = stop trading after 3% daily loss)
MAX_DAILY_LOSS_PCT=0.03

# Drawdown circuit-breaker (e.g. 0.10 = stop trading after 10% drawdown from peak)
MAX_DRAWDOWN_PCT=0.10

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Storage directories (relative to project root)
# ---------------------------------------------------------------------------
DATA_DIR=data
PARQUET_DIR=data/parquet
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
