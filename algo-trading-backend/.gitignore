# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
.Python

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
agents/.env

# ── Data (large files — store locally, never in git) ─────────────────────────
data/raw/*
data/processed/*
data/parquet/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/parquet/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Test / coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
